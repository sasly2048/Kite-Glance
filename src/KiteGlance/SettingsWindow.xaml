<Window x:Class="KiteGlance.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kite Glance"
        Width="400" Height="342"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Grid Background="{StaticResource Scrim}">

        <Border Height="1" VerticalAlignment="Top"
                Background="{StaticResource TopSheen}"
                IsHitTestVisible="False" />

        <StackPanel Margin="26,20,26,22">

            <Grid x:Name="DragBar" Background="Transparent" Height="26">
                <TextBlock Text="Settings"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource Label}"
                           VerticalAlignment="Center" />
                <Button x:Name="CloseButton" Content="&#10005;"
                        Style="{StaticResource IconButton}"
                        FontSize="11" HorizontalAlignment="Right" />
            </Grid>

            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="19"
                       Foreground="{StaticResource Label2}"
                       Margin="0,12,0,20">
                Create an app at <Run FontWeight="SemiBold"
                    Foreground="{StaticResource Label}">developers.kite.trade</Run>,
                then set its Redirect URL to<LineBreak />
                <Run FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                     Foreground="{StaticResource Blue}">http://127.0.0.1:5173/callback</Run>
            </TextBlock>

            <TextBlock Text="API key" FontSize="11" FontWeight="Medium"
                       Foreground="{StaticResource Label3}" Margin="1,0,0,6" />
            <TextBox x:Name="KeyBox" Style="{StaticResource Input}" />

            <TextBlock Text="API secret" FontSize="11" FontWeight="Medium"
                       Foreground="{StaticResource Label3}" Margin="1,14,0,6" />
            <PasswordBox x:Name="SecretBox" Style="{StaticResource Secret}" />

            <TextBlock x:Name="ErrorText" FontSize="11.5"
                       Foreground="{StaticResource Red}"
                       Margin="1,11,0,0" Visibility="Collapsed"
                       TextWrapping="Wrap" />

            <Button x:Name="SaveButton" Content="Save"
                    Style="{StaticResource Primary}"
                    HorizontalAlignment="Stretch" Margin="0,22,0,0" />

            <TextBlock FontSize="10.5" Margin="0,13,0,0"
                       TextAlignment="Center"
                       Foreground="{StaticResource Label4}"
                       Text="Encrypted with Windows DPAPI. Stays on this device." />
        </StackPanel>
    </Grid>
</Window>
