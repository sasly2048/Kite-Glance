<Application x:Class="KiteGlance.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:motion="clr-namespace:KiteGlance.Motion"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>

        <!--
            PALETTE
            Apple's dark-mode system colors. The four-step label ladder
            (100 / 55 / 30 / 18 percent white) is what gives Apple UI its depth
            without drawing a single line.
        -->
        <SolidColorBrush x:Key="Green" Color="#32D74B" />
        <SolidColorBrush x:Key="Red"   Color="#FF453A" />
        <SolidColorBrush x:Key="Blue"  Color="#0A84FF" />
        <SolidColorBrush x:Key="Amber" Color="#FF9F0A" />

        <SolidColorBrush x:Key="Label"  Color="#FFFFFF" />
        <SolidColorBrush x:Key="Label2" Color="#FFFFFF" Opacity="0.55" />
        <SolidColorBrush x:Key="Label3" Color="#FFFFFF" Opacity="0.30" />
        <SolidColorBrush x:Key="Label4" Color="#FFFFFF" Opacity="0.18" />

        <SolidColorBrush x:Key="Fill"      Color="#FFFFFF" Opacity="0.05" />
        <SolidColorBrush x:Key="Separator" Color="#FFFFFF" Opacity="0.08" />
        <SolidColorBrush x:Key="Track"     Color="#FFFFFF" Opacity="0.07" />

        <!--
            BACKDROP
            An actual rendered surface, not a tint: a mesh gradient of five
            soft colour fields (indigo, teal, violet, deep green, a cool centre
            lift), each with a gaussian falloff so none of them has a visible
            edge. Over it, a topographic contour field at 4 percent — a slow
            value-noise function sliced into bands, which reads as quiet
            structure, as something MADE, rather than a gradient with nothing
            in it. Then a vignette so the edges recede.

            Baked to Assets/backdrop.png rather than composed from XAML brushes,
            because the contour field is procedural noise that WPF has no
            primitive for. The grain tile still dithers it at runtime.
        -->
        <ImageBrush x:Key="Backdrop"
                    ImageSource="Assets/backdrop.png"
                    Stretch="UniformToFill"
                    AlignmentX="Left"
                    AlignmentY="Top" />

        <SolidColorBrush x:Key="Surface" Color="#FF101318" />

        <LinearGradientBrush x:Key="Scrim" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0"   Color="#FF14171D" />
            <GradientStop Offset="1"   Color="#FF0C0E12" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TopSheen" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0"   Color="#00FFFFFF" />
            <GradientStop Offset="0.5" Color="#26FFFFFF" />
            <GradientStop Offset="1"   Color="#00FFFFFF" />
        </LinearGradientBrush>

        <!--
            GRAIN
            A near-black vertical gradient on an 8-bit display bands: flat
            plateaus of colour with hard steps between them. Tiled monochrome
            noise at 2.5% dithers those plateaus into stochastic pixels, and the
            eye integrates them back into a smooth ramp.

            You have never consciously noticed this on Linear or Arc. That is
            exactly the point. It is felt, not seen.
        -->
        <ImageBrush x:Key="Grain"
                    ImageSource="Assets/grain.png"
                    TileMode="Tile"
                    Viewport="0,0,128,128"
                    ViewportUnits="Absolute"
                    Opacity="0.028"
                    Stretch="None" />


        <!--
            ICONS
            Vector, 16x16 grid, 1.6px stroke, round caps and joins.
            v5 used the text glyph U+22EE for the menu button: it inherits font
            metrics and sits on a baseline rather than an optical centre.
            Nothing in a premium product is a character pretending to be an icon.
        -->
        <GeometryGroup x:Key="IconMore">
            <EllipseGeometry Center="8,3.1"  RadiusX="1.15" RadiusY="1.15" />
            <EllipseGeometry Center="8,8"    RadiusX="1.15" RadiusY="1.15" />
            <EllipseGeometry Center="8,12.9" RadiusX="1.15" RadiusY="1.15" />
        </GeometryGroup>

        <PathGeometry x:Key="IconChevron" Figures="M 3.5,6.25 L 8,10.75 L 12.5,6.25" />
        <PathGeometry x:Key="IconArrow"   Figures="M 3.5,8 L 12.5,8 M 9,4.5 L 12.5,8 L 9,11.5" />
        <PathGeometry x:Key="IconCheck"   Figures="M 3.2,8.4 L 6.4,11.6 L 12.8,4.6" />


        <!--
            FOCUS
            v5 set FocusVisualStyle to null to kill Windows' dotted rectangle.
            That removed the interface for keyboard users — a regression, not a
            fix. A real ring, shown only when focus arrives from the keyboard.
        -->
        <Style x:Key="FocusRing">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="-3" RadiusX="10" RadiusY="10"
                                   Stroke="{StaticResource Blue}"
                                   StrokeThickness="2" Opacity="0.9"
                                   SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!--
            MOTION
            Two laws, and they differ on purpose.

            Layout SPRINGS. Overshoot reads as weight, as mass arriving.
            Numbers EASE. Overshoot would mean rendering a value you never held
            and then correcting it. Money must never overshoot.
        -->
        <motion:SpringEase x:Key="SpringLayout" Stiffness="170" Damping="20" EasingMode="EaseIn" />
        <motion:SpringEase x:Key="SpringGentle" Stiffness="130" Damping="22" EasingMode="EaseIn" />
        <motion:SpringEase x:Key="SpringSnap"   Stiffness="320" Damping="15" EasingMode="EaseIn" />


        <!-- ICON BUTTON -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
            <Setter Property="Foreground" Value="{StaticResource Label3}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="sc" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{StaticResource Fill}" />
                                <Setter Property="Foreground" Value="{StaticResource Label}" />
                            </Trigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="sc"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.9" Duration="0:0:0.07" />
                                        <DoubleAnimation Storyboard.TargetName="sc"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.9" Duration="0:0:0.07" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="sc"
                                            Storyboard.TargetProperty="ScaleX" To="1"
                                            Duration="0:0:0.42"
                                            EasingFunction="{StaticResource SpringSnap}" />
                                        <DoubleAnimation Storyboard.TargetName="sc"
                                            Storyboard.TargetProperty="ScaleY" To="1"
                                            Duration="0:0:0.42"
                                            EasingFunction="{StaticResource SpringSnap}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- EXPANDER -->
        <Style x:Key="Expander" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
            <Setter Property="Foreground" Value="{StaticResource Label2}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Separator}"
                                BorderThickness="0,1,0,0" Padding="20,13">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{StaticResource Fill}" />
                                <Setter Property="Foreground" Value="{StaticResource Label}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- TAB -->
        <Style x:Key="Tab" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
            <Setter Property="Foreground" Value="{StaticResource Label3}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="2,0,2,10">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Label2}" />
                </Trigger>
            </Style.Triggers>
        </Style>


        <!--
            HOLDING ROW
            Lifts 2px and its fill fades in on hover, both spring-eased.
            Restraint is the point: a row that leaps at the cursor is a row that
            will annoy you by the thousandth time you see it.
        -->
        <Style x:Key="Row" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation
                                    Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                    To="#12FFFFFF" Duration="0:0:0.18" />
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                    To="2" Duration="0:0:0.45"
                                    EasingFunction="{StaticResource SpringLayout}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation
                                    Storyboard.TargetProperty="Background.(SolidColorBrush.Color)"
                                    To="#00FFFFFF" Duration="0:0:0.26" />
                                <DoubleAnimation
                                    Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                    To="0" Duration="0:0:0.45"
                                    EasingFunction="{StaticResource SpringGentle}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>


        <!-- PRIMARY -->
        <Style x:Key="Primary" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#3395FF" />
                                    <GradientStop Offset="1" Color="#0A84FF" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="sc" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35" />
                            </Trigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="sc"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.97" Duration="0:0:0.07" />
                                        <DoubleAnimation Storyboard.TargetName="sc"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.97" Duration="0:0:0.07" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="sc"
                                            Storyboard.TargetProperty="ScaleX" To="1"
                                            Duration="0:0:0.45"
                                            EasingFunction="{StaticResource SpringSnap}" />
                                        <DoubleAnimation Storyboard.TargetName="sc"
                                            Storyboard.TargetProperty="ScaleY" To="1"
                                            Duration="0:0:0.45"
                                            EasingFunction="{StaticResource SpringSnap}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!--
            SKELETON
            Bars that breathe at the exact shape of the content arriving.
            Not a spinner. A spinner says "something is happening, somewhere".
            A skeleton says "your money will be here, in this shape, shortly".
        -->
        <Style x:Key="Bone" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Opacity" Value="0.06" />
            <Setter Property="CornerRadius" Value="5" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.05" To="0.11" Duration="0:0:1.05">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>


        <!-- INPUTS -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Fill}" />
            <Setter Property="Foreground" Value="{StaticResource Label}" />
            <Setter Property="CaretBrush" Value="{StaticResource Blue}" />
            <Setter Property="BorderBrush" Value="{StaticResource Separator}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,9" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{StaticResource Blue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Secret" TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource Fill}" />
            <Setter Property="Foreground" Value="{StaticResource Label}" />
            <Setter Property="CaretBrush" Value="{StaticResource Blue}" />
            <Setter Property="BorderBrush" Value="{StaticResource Separator}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,9" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{StaticResource Blue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- SCROLLBAR -->
        <Style x:Key="Hairline" TargetType="ScrollBar">
            <Setter Property="Width" Value="3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="0,4,3,4" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                            <Track.Thumb>
                                <Thumb Focusable="False">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#40FFFFFF" CornerRadius="2" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FadedList" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.OpacityMask>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0"    Color="#00000000" />
                                    <GradientStop Offset="0.05" Color="#FF000000" />
                                    <GradientStop Offset="0.93" Color="#FF000000" />
                                    <GradientStop Offset="1"    Color="#00000000" />
                                </LinearGradientBrush>
                            </Grid.OpacityMask>

                            <ScrollContentPresenter Margin="{TemplateBinding Padding}" />

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource Hairline}"
                                       HorizontalAlignment="Right"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="PART_VerticalScrollBar"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="PART_VerticalScrollBar"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0" Duration="0:0:0.45" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- CONTEXT MENU -->
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource Label}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd" Background="Transparent"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Margin="5,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Path x:Name="check" Grid.Column="0"
                                      Width="11" Height="11"
                                      HorizontalAlignment="Left" VerticalAlignment="Center"
                                      Data="{StaticResource IconCheck}"
                                      Stretch="Uniform"
                                      Stroke="{StaticResource Blue}"
                                      StrokeThickness="1.7"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />

                                <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Label4}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuSeparator" TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="12,5" />
            <Setter Property="Background" Value="{StaticResource Separator}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#F51A1C20" />
            <Setter Property="BorderBrush" Value="{StaticResource Separator}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0,5" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                MinWidth="196">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.55" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
