# Kite Glance - environment configuration
#
# Copy this file to `.env` and fill in your own values, OR set these as
# user-level environment variables. Either way, `.env` is git-ignored and
# will never be committed.
#
# These are consumed by Services/CredentialVault.cs, which checks the
# environment FIRST, falling back to the encrypted on-disk vault (filled in
# via the Settings dialog on first run). Setting these is optional -- if you
# skip this file entirely, the app will simply ask for your credentials the
# first time it launches.
#
# Get your API key and secret by creating an app at:
#   https://developers.kite.trade
#
# When creating the app, set its Redirect URL to exactly:
#   http://127.0.0.1:5173/callback

KITE_API_KEY=YOUR_KITE_API_KEY
KITE_API_SECRET=YOUR_KITE_API_SECRET
